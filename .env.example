# Copy this file to .env and fill in values. The app runs fine with defaults for local testing.

# Server
PORT=3000

# Secret used to sign login tokens. CHANGE THIS in production to a long random string.
JWT_SECRET=change-me-to-a-long-random-secret

# ---- Stripe (optional) ----
# Leave these blank to run in MOCK billing mode (upgrades work instantly, no real charges).
# Fill them in to take real payments. See GO-LIVE.md for setup steps.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
# The public URL of your app, used for Stripe redirects + email invoice links (e.g. https://yourapp.com)
APP_URL=http://localhost:3000

# ---- Email (optional, via Resend) ----
# Leave blank to run without email: the "Send to client" button still marks the
# invoice as sent and copies the shareable link. Add a key to send real emails.
# Get a free key at https://resend.com → API Keys.
RESEND_API_KEY=
# The "from" address. Until you verify your own domain in Resend, you can use
# the shared sandbox sender below (fine for testing).
EMAIL_FROM=InvoiceFlow <onboarding@resend.dev>
